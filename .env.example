# AI4Agri MVP environment

APP_ENV=development
APP_PORT=8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SUPABASE_URL=PASTE_YOUR_SUPABASE_URL_HERE
NEXT_PUBLIC_SUPABASE_ANON_KEY=PASTE_YOUR_SUPABASE_ANON_KEY_HERE

# Supabase backend
SUPABASE_URL=PASTE_YOUR_SUPABASE_URL_HERE
SUPABASE_ANON_KEY=PASTE_YOUR_SUPABASE_ANON_KEY_HERE
SUPABASE_SERVICE_KEY=PASTE_YOUR_SUPABASE_SERVICE_KEY_HERE
SUPABASE_JWT_SECRET=PASTE_YOUR_SUPABASE_JWT_SECRET_HERE

# AI services
GEMINI_API_KEY=PASTE_YOUR_GEMINI_API_KEY_HERE
DISEASE_MODEL_PATH=backend/ml/models/plant_disease_mobilenetv2.h5

# Local HuggingFace cache
HF_CACHE_DIR=backend/ml/cache

# Google Earth Engine
GEE_SERVICE_ACCOUNT=PASTE_YOUR_GEE_SERVICE_ACCOUNT_HERE
GEE_KEY_FILE=backend/secrets/gee_key.json

# Optional WhatsApp alerts
WHATSAPP_TOKEN=PASTE_YOUR_WHATSAPP_TOKEN_HERE
WHATSAPP_PHONE_ID=PASTE_YOUR_WHATSAPP_PHONE_ID_HERE
