# ════════════════════════════════════════════════
# AI4Agri MVP - Environment Variables
# ════════════════════════════════════════════════

# ------------------------------------------------
# 1. CORE APPLICATION
# ------------------------------------------------
# Set to 'development' or 'production' (Free)
APP_ENV=PASTE_YOUR_APP_ENV_HERE
# Application port (Free)
APP_PORT=PASTE_YOUR_APP_PORT_HERE
# Base API URL for frontend (Free)
NEXT_PUBLIC_API_URL=PASTE_YOUR_NEXT_PUBLIC_API_URL_HERE

# ------------------------------------------------
# 2. SUPABASE BACKEND (Database, Auth, Storage)
# Get from: https://supabase.com/dashboard/project/settings/api
# Cost: Free Tier available
# ------------------------------------------------
SUPABASE_URL=PASTE_YOUR_SUPABASE_URL_HERE
SUPABASE_ANON_KEY=PASTE_YOUR_SUPABASE_ANON_KEY_HERE
SUPABASE_SERVICE_KEY=PASTE_YOUR_SUPABASE_SERVICE_KEY_HERE
# Get JWT Secret from Supabase -> API Settings -> JWT Secret
SUPABASE_JWT_SECRET=PASTE_YOUR_SUPABASE_JWT_SECRET_HERE

# ------------------------------------------------
# 3. FASTAPI AUTH & JWT
# Used for backend token validation
# Cost: Free (Locally generated)
# ------------------------------------------------
JWT_SECRET_KEY=PASTE_YOUR_JWT_SECRET_KEY_HERE
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ------------------------------------------------
# 4. ARTIFICIAL INTELLIGENCE & ML
# ------------------------------------------------
# Get from: https://aistudio.google.com/
# Cost: Free Tier available
GEMINI_API_KEY=PASTE_YOUR_GEMINI_API_KEY_HERE

# Path to local disease CNN model
# Cost: Free (Local file)
DISEASE_MODEL_PATH=backend/ml/models/disease_model.h5

# HuggingFace Cache Directory
# Cost: Free (Local storage)
HF_CACHE_DIR=backend/ml/hf_cache

# ------------------------------------------------
# 5. GOOGLE EARTH ENGINE (Satellite NDVI)
# Get from: https://earthengine.google.com/ (Service Account)
# Cost: Free for Research/Non-Commercial
# ------------------------------------------------
GEE_SERVICE_ACCOUNT=PASTE_YOUR_GEE_SERVICE_ACCOUNT_HERE
GEE_KEY_FILE=PASTE_YOUR_GEE_KEY_FILE_HERE

# ------------------------------------------------
# 6. WHATSAPP META API (Alerts)
# Get from: https://developers.facebook.com/
# Cost: Free tier limits apply
# ------------------------------------------------
WHATSAPP_TOKEN=PASTE_YOUR_WHATSAPP_TOKEN_HERE
WHATSAPP_PHONE_ID=PASTE_YOUR_WHATSAPP_PHONE_ID_HERE

# ------------------------------------------------
# 7. FRONTEND SUPABASE (Next.js config)
# Same values as Section 2
# Cost: Free
# ------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=PASTE_YOUR_NEXT_PUBLIC_SUPABASE_URL_HERE
NEXT_PUBLIC_SUPABASE_ANON_KEY=PASTE_YOUR_NEXT_PUBLIC_SUPABASE_ANON_KEY_HERE
